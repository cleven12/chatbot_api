# Supabase (service role — server-side only, never expose to browsers)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Gemini (embeddings + LLM fallback)
GEMINI_API_KEY=your-gemini-api-key

# Groq (primary LLM — Llama 3.1)
GROQ_API_KEY=your-groq-api-key

# Admin key for /api/v1/ingest and /api/v1/tenants
ADMIN_API_KEY=generate-a-long-random-admin-secret
