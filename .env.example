# Supabase — MUST be the service_role secret (not anon / public)
# Supabase dashboard → Project Settings → API → service_role
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-secret

# Gemini (embeddings + LLM fallback)
GEMINI_API_KEY=your-gemini-api-key

# Groq (primary LLM — Llama 3.1)
GROQ_API_KEY=your-groq-api-key

# Admin key for /api/v1/ingest and /api/v1/tenants
ADMIN_API_KEY=generate-a-long-random-admin-secret

# Public site / SEO / contact (shown on marketing pages)
NEXT_PUBLIC_SITE_URL=https://tourragapi.vercel.app
NEXT_PUBLIC_CONTACT_PHONE=+255 754 225 781
NEXT_PUBLIC_CONTACT_PHONE_HREF=tel:+255754225781
NEXT_PUBLIC_CONTACT_WHATSAPP=https://wa.me/255754225781
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
NEXT_PUBLIC_CONTACT_EMAIL_HREF=mailto:you@example.com

